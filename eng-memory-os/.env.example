# ===========================
# Engineering Memory OS
# Environment Configuration
# ===========================

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-secure-random-string
APP_HOST=0.0.0.0
APP_PORT=8000

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=eng_memory
POSTGRES_PASSWORD=eng_memory_dev_password
POSTGRES_DB=eng_memory_os
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Qdrant Vector Database ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=eng_memory_chunks

# --- Cognee (Knowledge Graph) ---
COGNEE_GRAPH_BACKEND=networkx
# For Neo4j production setup, uncomment:
# COGNEE_GRAPH_BACKEND=neo4j
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=neo4j_dev_password

# --- LLM Gateway ---
# Primary provider: openai | anthropic | ollama
LLM_PRIMARY_PROVIDER=openai
LLM_FALLBACK_PROVIDER=ollama

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (Local LLM fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# LLM Gateway Settings
LLM_CIRCUIT_BREAKER_THRESHOLD_MS=5000
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_BASE=2.0

# --- JWT Authentication ---
JWT_SECRET_KEY=change-me-to-a-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Encryption ---
ENCRYPTION_KEY=change-me-to-a-32-byte-hex-key

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=eng-memory-os
LOG_LEVEL=INFO
LOG_FORMAT=json
